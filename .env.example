# Copy this file to .env.local and fill in your values.
# These VITE_* vars are baked into the browser bundle - acceptable for prototype.
# For production, move AI calls behind a Cloudflare Worker.

VITE_AI_PROVIDER=gemini

# Anthropic (optional, off by default)
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Google AI Studio (required for chat + listing AI)
VITE_GEMINI_API_KEY=AIza...

# Firebase web app config — Firebase Console -> Project settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Tidyup Worker API URL
VITE_API_BASE=https://tidyup-api.<your-subdomain>.workers.dev
