# Copy this file to .env.local and fill in your keys.
# Prototype only - these keys are exposed to the browser.
# For production, move AI calls behind a Cloudflare Worker so keys stay secret.

# Which provider to use by default: "claude" or "gemini"
VITE_AI_PROVIDER=claude

# Get from https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Get from https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=AIza...
